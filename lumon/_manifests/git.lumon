define git.status
  "Get git working tree status"
  takes: nothing
  returns: :ok(text) | :error(text) "Porcelain status output or error"

define git.log
  "Get recent commit history"
  takes:
    n: number "Number of commits to return"
  returns: :ok(list<text>) | :error(text) "List of hash-subject strings or error"
