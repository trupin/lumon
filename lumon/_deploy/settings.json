{
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(*)",
      "WebFetch",
      "Read",
      "Edit",
      "NotebookEdit"
    ],
    "allow": [
      "Bash(lumon --working-dir sandbox:*)",
      "Edit(./sandbox/**)",
      "Read(./**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": ["python3 .claude/hooks/sandbox-guard.py"]
      }
    ]
  }
}
