{
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "WebFetch",
      "NotebookEdit"
    ],
    "allow": [
      "Bash",
      "Read",
      "Edit"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/sandbox-guard.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/sandbox-guard.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/sandbox-guard.py"
          }
        ]
      }
    ]
  }
}